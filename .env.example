# ============================================================
# Libertas — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# --- Supabase --------------------------------------------------
# Pegue em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (a chave secreta service_role)

# --- Meta Ads --------------------------------------------------
# Não precisa preencher aqui — o token entra pela UI /configuracoes
# e fica gravado em fb_connections (criptografado).

# --- App config -----------------------------------------------
# URL pública do app (usado pra montar a URL do webhook)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Habilita dados mockados (true) ou conecta no Supabase (false)
# Útil pra desenvolver/demonstrar sem o banco configurado
USE_MOCK_DATA=false
